# PulsePay-SBI backend configuration.
# Secrets are delivered by Vault/KMS in production — never hardcoded. The server
# FAILS CLOSED if JWT_SECRET or KMS_DATA_KEY are missing.

# India-resident Postgres (RBI data localization)
DATABASE_URL=postgresql://pulsepay:CHANGE_ME@localhost:5432/pulsepay

# Auth (>=16 chars). From Vault/KMS in prod.
JWT_SECRET=CHANGE_ME_min_16_chars_secret
JWT_EXPIRY=24h

# KMS data key for biometric template envelope encryption (32 bytes hex = 64 chars).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KMS_DATA_KEY=

# India-resident CV / inference plane
CV_SERVICE_URL=http://localhost:8000
INDIA_MODEL_ALLOWLIST=

# Biometric matching threshold (FAR/FRR-calibrated in prod)
FACE_MATCH_THRESHOLD=0.86

# Risk tiers (paise) and distress cap (paise)
TIER_MED_PAISE=20000
TIER_HIGH_PAISE=100000
DISTRESS_CAP_PAISE=50000
AUTH_ASSERTION_TTL=90

# Notifications via an India DLT-registered gateway (mocked in this demo).
TWILIO_ACCOUNT_SID=your_sid_here
TWILIO_AUTH_TOKEN=your_token_here
TWILIO_PHONE_NUMBER=your_number_here

# CORS allow-list (no wildcard) + rate limit
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_PER_MIN=120

PORT=5000
NODE_ENV=development
