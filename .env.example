# Root env for docker-compose. Copy to .env and fill in. No defaults for secrets
# (compose fails closed without them — by design).

# Postgres (India-resident)
POSTGRES_USER=pulsepay
POSTGRES_PASSWORD=
POSTGRES_DB=pulsepay

# Backend secrets (from Vault/KMS in production)
JWT_SECRET=
# 32-byte hex (64 chars). Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KMS_DATA_KEY=

# CORS allow-list (no wildcard)
CORS_ORIGINS=http://localhost:3000

# Notifications (India DLT gateway; mocked in this demo)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Tuning
FACE_MATCH_THRESHOLD=0.86
DISTRESS_CAP_PAISE=50000
